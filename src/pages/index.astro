---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import StatBlock from '../components/StatBlock.astro';
import EngineCard from '../components/EngineCard.astro';
import Callout from '../components/Callout.astro';
import ValueItem from '../components/ValueItem.astro';
---
<BaseLayout title="Florida Space Innovation Center">

  <!-- ============================================
       HERO
       ============================================ -->
  <section class="bg-navy text-white py-24 md:py-32 lg:py-40 relative overflow-hidden section-divider section-divider--to-white">
    <!-- Hero background image -->
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${import.meta.env.BASE_URL}/images/fsic-hero.jpg')`}></div>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/30"></div>

    <div class="container relative z-10">
      <div class="max-w-3xl hero-stagger">
        <p class="text-orange font-semibold text-sm uppercase tracking-widest mb-6">
          Florida Space Innovation Center
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-8 hero-text-shadow">
          A New Commitment to the Space Coast
        </h1>
        <div class="text-lg md:text-xl text-white/90 leading-relaxed space-y-6 mb-12">
          <p>
            On May 25, 1961, the United States committed to landing a man on the Moon — not because it was easy, but because it demanded coordination, capability, and national resolve.
          </p>
          <p>
            Sixty-five years later, Southeast Volusia launches its own coordinated commitment: to strengthen our regional workforce, accelerate innovation, support industry growth, and ensure that the Space Coast's expansion directly benefits the people who live and work here.
          </p>
          <p class="font-semibold text-white">
            The Florida Space Innovation Center is that commitment in action.
          </p>
        </div>
        <div class="flex flex-wrap gap-4">
          <Button href="/model" variant="primary">Explore the Vision</Button>
          <Button href="/economic-impact" variant="secondary-light">View Economic Impact</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       THE STRATEGIC MOMENT
       ============================================ -->
  <Section id="strategic-moment" background="white">
    <div class="max-w-3xl mx-auto text-center reveal">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-navy leading-snug mb-8">
        The Question Is Not Whether the Space Coast Will Grow.<br />
        <span class="text-orange">It Is Whether Southeast Volusia Will Participate in That Growth.</span>
      </h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-6 text-lg text-gray-dark leading-relaxed reveal">
      <p>
        Florida's space economy is expanding rapidly — driven by commercial launch activity, advanced manufacturing, aerospace engineering, and emerging technologies.
      </p>
      <p>
        Without coordination, growth concentrates elsewhere.
      </p>
      <p>
        The Florida Space Innovation Center (FSIC) ensures that Southeast Volusia is not a spectator to that growth, but an active participant — building the talent, infrastructure, and partnerships required to compete in a global innovation economy.
      </p>
      <Callout>
        FSIC is designed to align education, industry, and community in one coordinated regional platform.
      </Callout>
    </div>
  </Section>

  <!-- ============================================
       THE ECONOMIC CASE
       ============================================ -->
  <Section id="economic-impact" background="navy" class="section-divider section-divider--to-light">
    <div class="reveal">
      <SectionHeader align="center" dark>
        <h2 slot="headline" class="text-white text-3xl md:text-4xl">Transformational, Long-Term Regional Impact</h2>
        <p slot="subhead">Independent 25-year analysis projects that FSIC will generate:</p>
      </SectionHeader>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-12 stat-grid reveal-group">
      <div class="reveal">
        <StatBlock
          value="$12.4B"
          label="Total economic output"
          dark
        />
      </div>
      <div class="reveal">
        <StatBlock
          value="79,500"
          label="Job-years across aerospace, engineering, manufacturing, and technology"
          dark
        />
      </div>
      <div class="reveal">
        <StatBlock
          value="$1.55B"
          label="In new wages for Florida workers"
          dark
        />
      </div>
      <div class="reveal">
        <StatBlock
          value="$910M"
          label="In fiscal revenue for local and state governments"
          dark
        />
      </div>
    </div>

    <div class="max-w-3xl mx-auto text-center space-y-6 reveal">
      <p class="text-lg text-white/85 leading-relaxed">
        In addition, FSIC positions the region to attract <strong class="text-white">$800 Million to $1.56 Billion</strong> in external federal, state, private, and philanthropic investment tied to research, innovation, and workforce development.
      </p>
      <Callout variant="dark">
        This is not a short-term program. It is a durable economic backbone.
      </Callout>
      <div class="pt-4">
        <Button href="/economic-impact" variant="secondary-light">Explore the Full Economic Analysis</Button>
      </div>
    </div>
  </Section>

  <!-- ============================================
       THE FOUR-ENGINE MODEL
       ============================================ -->
  <Section id="model" background="light">
    <div class="reveal">
      <SectionHeader align="center">
        <h2 slot="headline">One Coordinated Platform. Four Integrated Engines.</h2>
        <p slot="subhead">FSIC operates through a structured, phased model designed for early activation and long-term scale.</p>
      </SectionHeader>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-12 reveal-group">
      <div class="reveal">
        <EngineCard
          icon="talent"
          title="Talent Engine"
          subtitle="Transforming individuals into skilled talent"
          description="Drives employer-aligned training, micro-credential academies, dual-enrollment pathways, and industry-embedded learning."
        />
      </div>
      <div class="reveal">
        <EngineCard
          icon="innovation"
          title="Innovation Engine"
          subtitle="Transforming knowledge into innovation"
          description="Powers challenge labs, applied research partnerships, prototyping studios, and university collaboration."
        />
      </div>
      <div class="reveal">
        <EngineCard
          icon="market"
          title="Market Engine"
          subtitle="Transforming opportunity into market success"
          description="Accelerates supplier readiness, startup development, SBIR/STTR navigation, and venture pathways."
        />
      </div>
      <div class="reveal">
        <EngineCard
          icon="civic"
          title="Civic Engine"
          subtitle="Transforming innovation into shared identity"
          description="Engages the broader community through STEM programming, exhibitions, arts-and-space initiatives, and public events."
        />
      </div>
    </div>

    <div class="text-center space-y-6 reveal">
      <p class="text-lg text-gray-dark max-w-2xl mx-auto">
        Each engine reinforces the others. Together, they create a coordinated regional ecosystem.
      </p>
      <Button href="/model">Learn More About the FSIC Model</Button>
    </div>
  </Section>

  <!-- ============================================
       PHASED DEPLOYMENT
       ============================================ -->
  <Section id="deployment" background="white">
    <div class="reveal">
      <SectionHeader align="center">
        <h2 slot="headline">Start Small. Deliver Early Wins. Scale with Readiness.</h2>
      </SectionHeader>
    </div>

    <div class="max-w-3xl mx-auto space-y-6 text-lg text-gray-dark leading-relaxed">
      <p class="reveal">
        FSIC launches with the Talent Engine — requiring minimal physical footprint while delivering immediate workforce and employer-support outcomes.
      </p>
      <p class="reveal">
        As partnerships deepen and demand grows, the Innovation, Market, and Civic Engines scale in alignment with regional development timelines.
      </p>

      <div class="bg-gray-light rounded-lg p-8 my-8 reveal">
        <p class="font-semibold text-navy mb-6">This phased approach:</p>
        <div class="timeline reveal-group">
          <div class="timeline-item reveal">
            <p class="font-medium text-navy">Reduces risk</p>
            <p class="text-sm text-gray-dark mt-1">Incremental validation at every stage</p>
          </div>
          <div class="timeline-item reveal">
            <p class="font-medium text-navy">Aligns with funding cycles</p>
            <p class="text-sm text-gray-dark mt-1">Structured around federal, state, and private timelines</p>
          </div>
          <div class="timeline-item reveal">
            <p class="font-medium text-navy">Ensures operational discipline</p>
            <p class="text-sm text-gray-dark mt-1">Each phase proves readiness before scaling</p>
          </div>
          <div class="timeline-item reveal">
            <p class="font-medium text-navy">Builds momentum before expansion</p>
            <p class="text-sm text-gray-dark mt-1">Early wins generate stakeholder confidence</p>
          </div>
        </div>
      </div>

      <div class="reveal">
        <Callout>
          Growth is structured. Not speculative.
        </Callout>
      </div>

      <div class="text-center pt-4 reveal">
        <Button href="/deployment">View the Deployment Timeline</Button>
      </div>
    </div>
  </Section>

  <!-- ============================================
       STRATEGIC VALUE TO VOLUSIA COUNTY
       ============================================ -->
  <Section id="value" background="light">
    <div class="reveal">
      <SectionHeader align="center">
        <h2 slot="headline">Strategic Value to Volusia County</h2>
      </SectionHeader>
    </div>

    <div class="max-w-3xl mx-auto space-y-8 reveal-group">
      <div class="reveal">
        <ValueItem
          title="Year-Round Activation"
          description="Daily activity from students, educators, employers, and events supports small businesses and drives regional economic circulation."
        />
      </div>
      <div class="reveal">
        <ValueItem
          title="Talent Attraction & Retention"
          description="Integrated programming strengthens local career pathways and helps retain young professionals who want opportunity close to home."
        />
      </div>
      <div class="reveal">
        <ValueItem
          title="Employer Attraction & Higher-Wage Growth"
          description="By strengthening workforce alignment and innovation capacity, FSIC enhances Volusia County's competitiveness for aerospace and technology employers."
        />
      </div>
      <div class="reveal">
        <ValueItem
          title="Alignment with Major Funding Channels"
          description="FSIC is positioned to pursue and coordinate funding through NSF Engines, regional innovation grants, state workforce programs, and Space Florida tools — bringing outside dollars into the region."
        />
      </div>
    </div>

    <div class="max-w-3xl mx-auto mt-10 reveal">
      <Callout>
        This is a coordinated regional investment — not a standalone facility.
      </Callout>
    </div>
  </Section>

  <!-- ============================================
       LONG-RANGE VISION
       ============================================ -->
  <Section id="vision" background="navy" class="section-divider section-divider--to-white">
    <div class="reveal">
      <SectionHeader align="center" dark>
        <h2 slot="headline" class="text-white text-3xl md:text-4xl">A Landmark Campus at Deering Park</h2>
        <p slot="subhead">As the model matures, FSIC evolves into a permanent anchor institution for Southeast Volusia.</p>
      </SectionHeader>
    </div>

    <div class="max-w-3xl mx-auto">
      <p class="text-white/85 text-lg mb-6 reveal">The long-term vision includes:</p>
      <ul class="space-y-4 mb-10 reveal-group">
        <li class="flex items-start gap-4 text-white/85 text-lg reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          A multi-university consortium with shared research facilities
        </li>
        <li class="flex items-start gap-4 text-white/85 text-lg reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          Applied labs and innovation studios
        </li>
        <li class="flex items-start gap-4 text-white/85 text-lg reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          A multipurpose auditorium and performing arts center
        </li>
        <li class="flex items-start gap-4 text-white/85 text-lg reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          Public gathering spaces integrating arts, science, and community programming
        </li>
      </ul>

      <div class="border-l-4 border-orange pl-6 py-2 reveal">
        <p class="text-xl text-white font-semibold leading-relaxed">
          The future is built in phases.
        </p>
        <p class="text-xl text-orange font-semibold leading-relaxed">
          The commitment begins now.
        </p>
      </div>
    </div>
  </Section>

  <!-- ============================================
       GOVERNANCE & TRANSPARENCY
       ============================================ -->
  <Section id="governance" background="white">
    <div class="reveal">
      <SectionHeader align="center">
        <h2 slot="headline">Governance & Transparency</h2>
        <p slot="subhead">FSIC operates under a partner-first, coalition-driven governance structure.</p>
      </SectionHeader>
    </div>

    <div class="max-w-3xl mx-auto">
      <p class="text-lg text-gray-dark mb-6 reveal">It is designed to:</p>
      <ul class="space-y-4 mb-10 reveal-group">
        <li class="flex items-start gap-4 text-lg text-gray-dark reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          Strengthen — not compete with — existing institutions
        </li>
        <li class="flex items-start gap-4 text-lg text-gray-dark reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          Maintain transparent oversight
        </li>
        <li class="flex items-start gap-4 text-lg text-gray-dark reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          Deliver shared value across education, industry, and community stakeholders
        </li>
        <li class="flex items-start gap-4 text-lg text-gray-dark reveal">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-orange mt-2.5"></span>
          Scale only when readiness and demand are clear
        </li>
      </ul>

      <div class="reveal">
        <Callout>
          Neutral convener. Clear structure. Long-term accountability.
        </Callout>
      </div>

      <div class="text-center mt-8 reveal">
        <Button href="/governance">Review Governance & Structure</Button>
      </div>
    </div>
  </Section>

  <!-- ============================================
       FINAL CTA
       ============================================ -->
  <section class="bg-navy text-white section--lg relative overflow-hidden">
    <!-- Radial glow background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-orange/[0.04] rounded-full blur-3xl"></div>
    </div>

    <!-- Decorative grid pattern -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.03] pointer-events-none" aria-hidden="true">
      <defs>
        <pattern id="cta-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#cta-grid)" />
    </svg>

    <div class="container text-center relative z-10">
      <div class="reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Partner. Collaborate. Participate.
        </h2>
      </div>
      <div class="reveal">
        <p class="text-lg text-white/85 leading-relaxed max-w-2xl mx-auto mb-4">
          The Florida Space Innovation Center represents a coordinated investment in the region's future.
        </p>
        <p class="text-lg text-white/85 leading-relaxed max-w-2xl mx-auto mb-10">
          Whether you are an employer, university leader, policymaker, workforce partner, or community member, there is a role to play in shaping Southeast Volusia's place in the global space economy.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-4 reveal">
        <Button href="/partnership-funding" variant="primary">Become a Partner</Button>
        <Button href="/contact" variant="secondary-light">Contact FSIC</Button>
      </div>
    </div>
  </section>

</BaseLayout>
