---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<div class="section--lg">
  <div class="container">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-orange font-semibold text-sm uppercase tracking-widest mb-4">Coming Soon</p>
      <h1 class="text-3xl md:text-4xl font-bold text-navy mb-6">{title}</h1>
      <p class="text-lg text-gray-dark leading-relaxed mb-10">{description}</p>
      <a
        href="/"
        class="inline-block px-8 py-3.5 text-base font-semibold rounded-md bg-navy text-white hover:bg-navy-light transition-colors"
      >
        Return to Home
      </a>
    </div>
  </div>
</div>
