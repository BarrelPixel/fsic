---
interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;
---
<div class:list={[
  'border-l-4 border-orange px-6 py-5 rounded-r-md',
  variant === 'dark' ? 'bg-navy-light/50' : 'bg-gray-light',
]}>
  <p class:list={[
    'text-lg leading-relaxed font-medium',
    variant === 'dark' ? 'text-white/90' : 'text-navy',
  ]}>
    <slot />
  </p>
</div>
