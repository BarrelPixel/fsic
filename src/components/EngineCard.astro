---
<div class="group bg-white border-t-4 border-orange rounded-md shadow-sm p-8 flex flex-col transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-orange/10">
  <div class="text-orange mb-4 transition-transform duration-300 group-hover:scale-110" set:html={icons[icon]} />
  <h3 class="text-xl font-semibold text-navy mb-1">{title}</h3>
  <p class="text-sm text-gray italic mb-4">{subtitle}</p>
  <p class="text-gray-dark leading-relaxed">{description}</p>
</div>
