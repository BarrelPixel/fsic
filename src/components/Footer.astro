---
const base = import.meta.env.BASE_URL;
const primaryLinks = [
  { label: 'Home', href: base },
  { label: 'The Model', href: `${base}/model` },
  { label: 'Economic Impact', href: `${base}/economic-impact` },
  { label: 'Deployment', href: `${base}/deployment` },
  { label: 'Governance', href: `${base}/governance` },
  { label: 'Contact', href: `${base}/contact` },
];

const secondaryLinks = [
  { label: 'The Strategic Moment', href: `${base}/strategic-moment` },
  { label: 'Programs & Facilities', href: `${base}/programs-facilities` },
  { label: 'Partnership & Funding', href: `${base}/partnership-funding` },
  { label: 'Long-Term Vision', href: `${base}/long-term-vision` },
];
---
<footer class="bg-navy text-white/80" role="contentinfo">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <p class="text-white font-bold text-lg leading-tight mb-1">Florida Space Innovation Center</p>
        <p class="text-sm text-orange font-medium mb-4">Southeast Volusia County, Florida</p>
        <p class="text-sm leading-relaxed">
          A coordinated regional platform strengthening workforce, innovation, and economic growth for the Space Coast.
        </p>
      </div>

      <!-- Primary Links -->
      <div>
        <p class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Navigation</p>
        <ul class="flex flex-col gap-2" role="list">
          {primaryLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Secondary Links -->
      <div>
        <p class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Explore</p>
        <ul class="flex flex-col gap-2" role="list">
          {secondaryLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/50">
        &copy; {new Date().getFullYear()} Florida Space Innovation Center. All rights reserved.
      </p>
      <p class="text-xs text-white/50">
        Built by <span class="text-white/70">Barrel &amp; Pixel</span>
      </p>
    </div>
  </div>
</footer>
