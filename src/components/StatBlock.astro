---
interface Props {
  value: string;
  label: string;
  dark?: boolean;
}

const { value, label, dark = false } = Astro.props;
---
<div class="text-center">
  <p
    class="text-3xl md:text-4xl font-bold text-orange leading-tight mb-2"
    data-counter
    data-value={value}
  >
    {value}
  </p>
  <p class:list={[
    'text-sm font-medium leading-snug',
    dark ? 'text-white/80' : 'text-gray-dark',
  ]}>
    {label}
  </p>
</div>
